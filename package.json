{
  "name": "gridlock",
  "private": true,
  "version": "0.1.0",
  "productName": "GRIDLOCK",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:live": "node scripts/run-electron-dev.mjs",
    "desktop:mac": "node scripts/create-macos-desktop-app.mjs",
    "level:validate": "tsx scripts/level-cli.ts validate",
    "level:render": "tsx scripts/level-cli.ts render",
    "level:export": "tsx scripts/level-cli.ts export",
    "level:load-json": "tsx scripts/level-cli.ts load-json",
    "test": "tsx --test tests/level-system.test.ts",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@types/node": "^25.9.3",
    "electron": "^42.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
